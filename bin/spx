#!/bin/bash
# Toggle SPX profiler on/off
# Usage:
#   bin/spx on   -> enable SPX web UI
#   bin/spx off  -> disable SPX (default)
#
# When enabled, the Web UI URL is printed based on BASE_URL and SPX_KEY from .env

set -e

MODE="${1:-on}"
COMPOSE_DIR="$(cd "$(dirname "$0")/.." && pwd)"

case "$MODE" in
    on)   SPX_VAL="1" ;;
    off)  SPX_VAL="0" ;;
    *)
        echo "Usage: bin/spx [on|off]"
        exit 1
        ;;
esac

echo "Setting SPX_ENABLED=$SPX_VAL"

if [ -f "$COMPOSE_DIR/.env" ]; then
    sed -i "s/^SPX_ENABLED=.*/SPX_ENABLED=$SPX_VAL/" "$COMPOSE_DIR/.env"
fi

# Source env vars for URL display
set -a
source "$COMPOSE_DIR/.env"
set +a

BASE_URL="${BASE_URL:-http://localhost}"
SPX_KEY="${SPX_KEY:-dev}"

# Restart PHP-FPM to pick up the change
docker compose restart php

if [ "$SPX_VAL" = "1" ]; then
    echo ""
    echo "SPX Profiler enabled!"
    echo "  Web UI:   ${BASE_URL}/?SPX_KEY=${SPX_KEY}&SPX_UI_URI=/"
    echo "  Profile:  Add ?SPX_KEY=${SPX_KEY}&SPX_ENABLED=1 to any URL"
else
    echo "SPX Profiler disabled."
fi
