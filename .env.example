# Magento 2.4.7 Dev Container Configuration

# User/Group ID (match your host user for file permissions)
USER_ID=1000
GROUP_ID=1000

# MySQL
MYSQL_ROOT_PASSWORD=magento
MYSQL_DATABASE=magento
MYSQL_USER=magento
MYSQL_PASSWORD=magento

# Magento Admin
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

# RabbitMQ
RABBITMQ_USER=magento
RABBITMQ_PASSWORD=magento

# Composer Auth (required for Magento installation)
# Get your keys at: https://marketplace.magento.com/customer/accessKeys/
# Format: {"http-basic":{"repo.magento.com":{"username":"PUBLIC_KEY","password":"PRIVATE_KEY"}}}
COMPOSER_AUTH=

# Store URL (used as Magento base URL; override with: bin/start http://mystore.local)
BASE_URL=http://localhost

# Port Mapping (change if you have conflicts)
NGINX_PORT=80
MYSQL_PORT=3306
OPENSEARCH_PORT=9200
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
MAILHOG_PORT=8025

# Debugging
# Xdebug: off, debug, profile, trace, coverage
XDEBUG_MODE=off
# SPX Profiler: 0=disabled, 1=enabled
SPX_ENABLED=0
SPX_KEY=dev

# Sample Data: 0=skip, 1=install
INSTALL_SAMPLE_DATA=0
